[debug] [2026-04-23T01:29:48.221Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/pos-v2-909ff/rulesets {"name":"projects/pos-v2-909ff/rulesets/295afbba-6440-49b0-9bd1-64aa0580ab38","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function signedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function userDoc() {\r\n      return get(/databases/$(database)/documents/users/$(request.auth.uid));\r\n    }\r\n\r\n    function userRole() {\r\n      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))\r\n        ? userDoc().data.role\r\n        : null;\r\n    }\r\n\r\n    function isAdmin() {\n      return userRole() in ['admin', 'manager'];\n    }\n\n    function isKitchen() {\n      return userRole() == 'kitchen';\n    }\n\r\n    match /System_Logs/{logId} {\r\n      allow create: if signedIn();\r\n      allow read: if isAdmin();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /Staff/{staffId} {\r\n      allow read: if signedIn();\r\n      allow create, update, delete: if isAdmin();\r\n    }\r\n\r\n    match /config/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /users/{userId} {\n      allow read: if signedIn();\n      allow write: if signedIn() && !isKitchen();\n    }\n\n    match /tables/{docId} {\n      allow read: if signedIn();\n      allow write: if signedIn() && !isKitchen();\n    }\n\n    match /orders/{docId} {\n      allow read: if signedIn();\n      allow create, delete: if signedIn() && !isKitchen();\n      allow update: if (signedIn() && !isKitchen()) || (\n        isKitchen() &&\n        resource.data.status == 'open' &&\n        request.resource.data.id == resource.data.id &&\n        request.resource.data.tableId == resource.data.tableId &&\n        request.resource.data.tableName == resource.data.tableName &&\n        request.resource.data.staffUid == resource.data.staffUid &&\n        request.resource.data.createdBy == resource.data.createdBy &&\n        request.resource.data.createdByRole == resource.data.createdByRole &&\n        request.resource.data.discount == resource.data.discount &&\n        request.resource.data.discountType == resource.data.discountType &&\n        request.resource.data.shipping == resource.data.shipping &&\n        request.resource.data.vatAmount == resource.data.vatAmount &&\n        request.resource.data.note == resource.data.note &&\n        request.resource.data.status == resource.data.status &&\n        request.resource.data.openedAt == resource.data.openedAt\n      );\n    }\n\r\n    match /menu/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /inventory/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /history/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /expenses/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /purchases/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /suppliers/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /shiftLogs/{docId} {\n      allow read, write: if signedIn();\n    }\n\n    match /kitchen_notifications/{docId} {\n      allow read: if signedIn();\n      allow create: if isKitchen() || isAdmin();\n      allow update: if signedIn();\n      allow delete: if isAdmin();\n    }\n\r\n    match /aiHistory/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /unitConversions/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /pending_users/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /Product_Catalog/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /Inventory_Items/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /Recipes_BOM/{docId} {\r\n      allow read, write: if signedIn();\r\n    }\r\n\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-04-23T01:29:48.707903Z","metadata":{"services":["cloud.firestore"]}}
