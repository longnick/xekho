rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc().data.role
        : null;
    }

    function isAdmin() {
      return userRole() in ['admin', 'manager'];
    }

    function isKitchen() {
      return userRole() == 'kitchen';
    }

    match /System_Logs/{logId} {
      allow create: if signedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /Staff/{staffId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /config/{docId} {
      allow read, write: if signedIn();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && !isKitchen();
    }

    match /tables/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && !isKitchen();
    }

    match /orders/{docId} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && !isKitchen();
      allow update: if (signedIn() && !isKitchen()) || (
        isKitchen() &&
        resource.data.status == 'open' &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.tableId == resource.data.tableId &&
        request.resource.data.tableName == resource.data.tableName &&
        request.resource.data.staffUid == resource.data.staffUid &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdByRole == resource.data.createdByRole &&
        request.resource.data.discount == resource.data.discount &&
        request.resource.data.discountType == resource.data.discountType &&
        request.resource.data.shipping == resource.data.shipping &&
        request.resource.data.vatAmount == resource.data.vatAmount &&
        request.resource.data.note == resource.data.note &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.openedAt == resource.data.openedAt
      );
    }

    match /menu/{docId} {
      allow read, write: if signedIn();
    }

    match /inventory/{docId} {
      allow read, write: if signedIn();
    }

    match /history/{docId} {
      allow read, write: if signedIn();
    }

    match /expenses/{docId} {
      allow read, write: if signedIn();
    }

    match /purchases/{docId} {
      allow read, write: if signedIn();
    }

    match /suppliers/{docId} {
      allow read, write: if signedIn();
    }

    match /shiftLogs/{docId} {
      allow read, write: if signedIn();
    }

    match /kitchen_notifications/{docId} {
      allow read: if signedIn();
      allow create: if isKitchen() || isAdmin();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /aiHistory/{docId} {
      allow read, write: if signedIn();
    }

    match /unitConversions/{docId} {
      allow read, write: if signedIn();
    }

    match /pending_users/{docId} {
      allow read, write: if signedIn();
    }

    match /Product_Catalog/{docId} {
      allow read, write: if signedIn();
    }

    match /Inventory_Items/{docId} {
      allow read, write: if signedIn();
    }

    match /Recipes_BOM/{docId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
